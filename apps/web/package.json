{
  "name": "web",
  "version": "0.0.1",
  "scripts": {
    "build": "next build",
    "dev": "dotenv -e ../../.env next dev",
    "start": "next start",
    "clean": "rm -rf .next && rm -rf .open-next && rm -rf node_modules",
    "cf-build": "opennextjs-cloudflare build",
    "deploy-dev": "opennextjs-cloudflare deploy --env development",
    "deploy-prod": "opennextjs-cloudflare deploy --env production",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@anju/ui": "*",
    "@anju/utils": "*",
    "better-auth": "^1.6.16",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@anju/tsconfig": "*",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
