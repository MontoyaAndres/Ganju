---
import Base from '../layouts/Base.astro';
---

<Base title="Privacy" description="How Ganju handles your data.">
  <section class="section">
    <article class="container narrow prose reveal">
      <h1>Privacy</h1>
      <p class="lead">This page is a placeholder — replace it with your privacy policy.</p>
      <p>
        Your passwords and keys are encrypted, never shown in plain text, and never shared.
        Everything runs on Cloudflare's secure global network. If you self-host Ganju, your data
        stays entirely in your own account.
      </p>
    </article>
  </section>
</Base>
